# Vaurex Backend Environment Variables
# Copy this file to .env and fill in your actual values

# API Keys (required for full functionality)
GEMINI_API_KEY=AIzaSy...your actual gemini key
GROQ_API_KEY=gsk_...your actual groq key
OPENROUTER_API_KEY=sk-or-...your actual openrouter key
DEEPSEEK_API_KEY=sk-...your actual deepseek key

# Supabase Configuration (required)
SUPABASE_URL=https://abcdefgh.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...your actual key

# Application URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Rate Limiting (requests per minute)
UPLOAD_RATE_LIMIT_PER_MIN=12
SCANS_RATE_LIMIT_PER_MIN=120
SCANS_DELETE_RATE_LIMIT_PER_MIN=60
AUTH_RATE_LIMIT_PER_MIN=180
CHAT_RATE_LIMIT_PER_MIN=45
SUPPORT_RATE_LIMIT_PER_MIN=20

# Support Email (SMTP)
SUPPORT_EMAIL=your-email@gmail.com
SUPPORT_EMAIL_PASSWORD=your-app-password
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
    